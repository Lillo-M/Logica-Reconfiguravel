library ieee;
  use ieee.std_logic_1164.all;
  use ieee.numeric_std.all;

entity totalizadores is
  port (
    clk    : in    std_logic;
    en     : in    std_logic;
    rst    : in    std_logic;
    clr    : in    std_logic;
    input  : in   std_logic_vector(4 downto 0);
    tot1   : out   std_logic_vector(2 downto 0)
    );
end entity totalizador_A;


architecture totalizador_A_arch of totalizador_A is
  signal tot_1 : unsigned (2 downto 0); -- 2^3 = 8 > 5

  signal tot_1_count : unsigned (4 downto 0) := "00001";

  signal tot_1_and : unsigned (4 downto 0) := "00000";
begin
  tot_1_and <= tot_1_count and unsigned(input);
  
  totalizador_1 : process (clk, rst, clr) is
  begin
    if (rst = '1') then
      tot_1 <= (others => '0');
      tot_1_count <= "00001";
    elsif (clk'event and clk = '1') then
      if (clr = '1') then
        tot_1 <= (others => '0');
        tot_1_count <= "00001";
      else
        if (tot_1_and /= "00000") then
          tot_1 <= tot_1 + 1;
        end if;
        tot_1_count <= shift_left(tot_1_count, 1);
      end if;
    end if;
  end process totalizador_1;

end architecture totalizador_A_arch;
